diff --git a/BUILD.gn b/BUILD.gn
index 4edba9f43..0b3e773ca 100644
--- a/BUILD.gn
+++ b/BUILD.gn
@@ -221,6 +221,7 @@ group("pdfium_public_headers") {
 
 component("pdfium") {
   output_name = "pdfium"
+  output_extension = "html"
   libs = []
   configs += [ ":pdfium_strict_config" ]
   public_configs = [ ":pdfium_public_config" ]
@@ -271,6 +272,34 @@ component("pdfium") {
     complete_static_lib = true
     configs -= [ "//build/config/compiler:thin_archive" ]
   }
+
+  if (is_wasm) {
+    exported_functions = exec_script(
+      "//build/toolchain/wasm/exported_functions.py",
+      [rebase_path("public")],
+      "trim string"
+    )
+
+    ldflags = [
+      "-sEXPORTED_FUNCTIONS=$exported_functions",
+      "-sLLD_REPORT_UNDEFINED",
+      "-sWASM=1",
+      "-sALLOW_MEMORY_GROWTH=1",
+      "-sEXPORTED_RUNTIME_METHODS=ccall,cwrap",
+      "--no-entry",
+    ]
+
+    if (is_debug) {
+      ldflags += [
+        "--profile",
+        "-g",
+      ]
+    } else {
+      ldflags += [
+        "-O2",
+      ]
+    }
+  }
 }
 
